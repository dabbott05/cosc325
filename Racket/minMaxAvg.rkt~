; recursive function to add up all the numbers in the list

(define (suml lis)
  (if (= (length lis) 1)
      ; car is the function that gives you the first item in a list
      (car lis)
      (+ (car lis) (suml (cdr lis)))))

; no error checking
(define (avgl lis)
  (/ (suml lis) (length lis)))

; with  error checking
(define (avglE lis)
  (if (empty? lis)
      (print "error")
      (/ (suml lis) (length lis))))

; min element in list
;base case - 1 item lest, that item is the min
; recursive step - trciky!
(define (minl lis)
  (if (= (length lis) 1)
      (car lis)
      (if (< (car lis) (minl (cdr lis)))
             (car lis)
             (minl (cdr lis)))))

(define (maxl lis)
  (if (= (length lis) 1)
      (car lis)
      (if (> (car lis) (maxl (cdr lis)))
             (car lis)
             (maxl (cdr lis)))))